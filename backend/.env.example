DATABASE_URL=sqlite:///./avris.db
SECRET_KEY=your-secret-key-here
RESEND_API_KEY=your-resend-key
FRONTEND_URL=http://localhost:8080

# OpenAI Whisper STT
OPENAI_API_KEY=sk-...
WHISPER_MODEL=whisper-1

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google OAuth — get from https://console.cloud.google.com/apis/credentials
# Add BOTH the localhost URI (for dev) and the Railway URI (for prod) to the
# OAuth client's "Authorized redirect URIs" list. Set this var to whichever
# one matches the env you're running.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# prod: https://avris-production-3e05.up.railway.app/api/auth/google/callback

# Mail.ru OAuth — get from https://oauth.mail.ru/app
MAILRU_CLIENT_ID=
MAILRU_CLIENT_SECRET=
MAILRU_REDIRECT_URI=http://localhost:8000/api/auth/mailru/callback
# prod: https://avris-production-3e05.up.railway.app/api/auth/mailru/callback